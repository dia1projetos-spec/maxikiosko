rules_version = '2';

// ============================================================
// REGLAS DE SEGURIDAD — Kiosko D. Diego
// ============================================================
// Cómo aplicarlas:
//   1. Entrá a la consola de Firebase → Firestore Database → pestaña "Reglas"
//   2. Pegá el contenido de este archivo completo
//   3. Publicar
//
// Lógica general:
//   - Lectura pública: config, slides, categories, products (los necesita
//     la tienda online, que no requiere login).
//   - Escritura: solo usuarios autenticados (el panel administrativo).
//   - clients y sales: solo usuarios autenticados (lectura y escritura),
//     porque contienen datos sensibles del negocio.
//   - orders: cualquiera puede CREAR un pedido (lo hace un cliente sin
//     login desde la tienda), pero solo el admin autenticado puede leer,
//     modificar o borrar pedidos.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /slides/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /clients/{docId} {
      allow read, write: if request.auth != null;
    }

    match /sales/{docId} {
      allow read, write: if request.auth != null;
    }

    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }

    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
